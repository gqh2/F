// UTILITY FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════════════

get_session(bar_time) =>
    hour_utc = hour(bar_time, "GMT")
    minute_utc = minute(bar_time, "GMT")
    time_in_minutes = hour_utc * 60 + minute_utc
    
    session_name = "Other"
    
    if time_in_minutes >= 480 and time_in_minutes < 1020
        session_name := "London"
    else if time_in_minutes >= 780 and time_in_minutes < 1320
        session_name := "NY"
    else if time_in_minutes >= 0 and time_in_minutes < 540
        session_name := "Asian"
    
    session_name

calc_pips(price_diff) =>
    pip_value = syminfo.mintick * 10
    math.round(price_diff / pip_value)

get_text_size(size_str) =>
    switch size_str
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        "Huge" => size.huge
        => size.normal

// UNIVERSAL ZONE HEIGHT NORMALIZATION
get_normalized_zone_height(atr_val) =>
    if use_normalized_zones
        if zone_height_method == "ATR Based"
            atr_val * zone_height_atr_mult
        else
            close * (zone_height_percent / 100.0)
    else
        na

normalize_zone(original_top, original_bottom, is_bullish, atr_val) =>
    if use_normalized_zones
        target_height = get_normalized_zone_height(atr_val)
        original_mid = (original_top + original_bottom) / 2
        
        new_top = original_mid + (target_height / 2)
        new_bottom = original_mid - (target_height / 2)
        
        [new_top, new_bottom]
    else
        [original_top, original_bottom]

// ══════════════════════════════════════════════════════════════════════════════════════
// STRENGTH RATING FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════════════

calculate_ob_strength(displacement, zone_height, session_name, age, atr_val) =>
    if not enable_strength_rating
        5.0
    else
        disp_score = 0.0
        if atr_val > 0
            disp_ratio = displacement / atr_val
            if disp_ratio >= 3.0
                disp_score := 3.0
            else if disp_ratio >= 2.0
                disp_score := 2.5
            else if disp_ratio >= 1.5
                disp_score := 2.0
            else if disp_ratio >= 1.0
                disp_score := 1.5
            else
                disp_score := 1.0
        else
            disp_score := 1.0
        
        sess_score = 0.0
        if session_name == "London" or session_name == "NY"
            sess_score := 2.0
        else if session_name == "Asian"
            sess_score := 1.0
        else
            sess_score := 0.5
        
        age_score = 0.0
        if age < 50
            age_score := 2.0
        else if age < 100
            age_score := 1.5
        else if age < 200
            age_score := 1.0
        else
            age_score := 0.5
        
        zone_score = 0.0
        if atr_val > 0
            zone_ratio = zone_height / atr_val
            if zone_ratio >= 0.5 and zone_ratio <= 2.0
                zone_score := 3.0
            else if zone_ratio >= 0.3 and zone_ratio <= 3.0
                zone_score := 2.0
            else
                zone_score := 1.0
        else
            zone_score := 1.5
        
        total = disp_score + sess_score + age_score + zone_score
        math.min(math.max(total, 0.0), 10.0)

calculate_fvg_strength(gap_size, atr_value) =>
    if not enable_strength_rating
        5.0
    else
        gap_score = 0.0
        if atr_value > 0
            gap_ratio = gap_size / atr_value
            if gap_ratio >= 1.5
                gap_score := 8.0
            else if gap_ratio >= 1.0
                gap_score := 6.0
            else if gap_ratio >= 0.75
                gap_score := 4.5
            else if gap_ratio >= 0.5
                gap_score := 3.0
            else
                gap_score := 1.5
        else
            gap_score := 3.0
        
        math.min(math.max(gap_score, 0.0), 10.0)

// ══════════════════════════════════════════════════════════════════════════════════════
// PRECALCULATE FUNCTIONS
