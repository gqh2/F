atr_value = ta.atr(14)
swing_high_ms = ta.pivothigh(high, swing_length, swing_length)
swing_low_ms = ta.pivotlow(low, swing_length, swing_length)
swing_high_ob = ta.pivothigh(high, ob_swing_length, ob_swing_length)
swing_low_ob = ta.pivotlow(low, ob_swing_length, ob_swing_length)
pivot_high_bb = ta.pivothigh(high, bb_swing_length, bb_swing_length)
pivot_low_bb = ta.pivotlow(low, bb_swing_length, bb_swing_length)

// ══════════════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE DETECTION (NO DUPLICATES - ONLY 1 LABEL PER BREAK)
// ══════════════════════════════════════════════════════════════════════════════════════

if barstate.isconfirmed
    // Update swing highs/lows when new pivots form
    if not na(swing_high_ms)
        last_swing_high := swing_high_ms
        last_swing_high_idx := bar_index - swing_length
    
    if not na(swing_low_ms)
        last_swing_low := swing_low_ms
        last_swing_low_idx := bar_index - swing_length
    
    // ABSOLUTE SINGLE LABEL ENFORCEMENT
    // Check if we've already labeled this exact swing level
    bool already_labeled_this_high = not na(last_labeled_high) and not na(last_swing_high) and math.abs(last_swing_high - last_labeled_high) < syminfo.mintick * 5
    bool already_labeled_this_low = not na(last_labeled_low) and not na(last_swing_low) and math.abs(last_swing_low - last_labeled_low) < syminfo.mintick * 5
    
    // Check bullish break (price above last high)
    if not na(last_swing_high) and close > last_swing_high and bar_index > last_structure_label_bar + 20 and not already_labeled_this_high
        // Determine label type based on previous trend
        bool create_label = false
        string label_text = ""
        color label_color = color.white
        
        if swing_trend == -1 and show_choch
            // Was bearish, now bullish = CHoCH
            create_label := true
            label_text := "CHoCH"
            label_color := choch_bull_color
        else if swing_trend == 1 and show_bos
            // Was bullish, still bullish = BOS
            create_label := true
            label_text := "BOS"
            label_color := bos_bull_color
        else if swing_trend == 0 and show_bos
            // Neutral to bullish = BOS
            create_label := true
            label_text := "BOS"
            label_color := bos_bull_color
        
        if create_label
            line.new(last_swing_high_idx, last_swing_high, bar_index, last_swing_high, 
                 color=label_color, width=2, style=line.style_dashed)
            label.new(bar_index, last_swing_high, label_text, 
                 color=color.new(color.black, 100), textcolor=label_color, 
                 style=label.style_none, size=size.normal)
            last_structure_label_bar := bar_index
            last_labeled_high := last_swing_high
        
        swing_trend := 1
    
    // Check bearish break (price below last low) - ONLY if no bullish break occurred
    else if not na(last_swing_low) and close < last_swing_low and bar_index > last_structure_label_bar + 20 and not already_labeled_this_low
        // Determine label type based on previous trend
        bool create_label = false
        string label_text = ""
        color label_color = color.white
        
        if swing_trend == 1 and show_choch
            // Was bullish, now bearish = CHoCH
            create_label := true
            label_text := "CHoCH"
            label_color := choch_bear_color
        else if swing_trend == -1 and show_bos
            // Was bearish, still bearish = BOS
            create_label := true
            label_text := "BOS"
            label_color := bos_bear_color
        else if swing_trend == 0 and show_bos
            // Neutral to bearish = BOS
            create_label := true
            label_text := "BOS"
            label_color := bos_bear_color
        
        if create_label
            line.new(last_swing_low_idx, last_swing_low, bar_index, last_swing_low, 
                 color=label_color, width=2, style=line.style_dashed)
            label.new(bar_index, last_swing_low, label_text, 
                 color=color.new(color.black, 100), textcolor=label_color, 
                 style=label.style_none, size=size.normal)
            last_structure_label_bar := bar_index
            last_labeled_low := last_swing_low
        
        swing_trend := -1

// ══════════════════════════════════════════════════════════════════════════════════════
// ORDER BLOCK DETECTION WITH NORMALIZED ZONES
// ══════════════════════════════════════════════════════════════════════════════════════

if show_order_blocks and barstate.isconfirmed
    // Bullish OB
    if not na(swing_low_ob)
        bool found = false
        float ob_top = na
        float ob_bot = na
        int ob_bar = na
        int ob_time_offset = na
        
        for i = ob_swing_length + 1 to ob_swing_length + ob_lookback
            if not found
                hist_close = close[i]
                hist_open = open[i]
                hist_high = high[i]
                hist_low = low[i]
                
                if hist_close < hist_open
                    disp = swing_low_ob - hist_low
                    rng = hist_high - hist_low
                    
                    if disp > (rng * ob_displacement_mult) and rng > 0
                        ob_top := hist_high
                        ob_bot := hist_low
                        ob_bar := bar_index - i
                        ob_time_offset := i
                        found := true

        if found and not na(ob_top)
            ob_session = get_session(time[ob_time_offset])
            age = 0
            displacement = close - ob_bot
            zone_height = ob_top - ob_bot
            strength = calculate_ob_strength(displacement, zone_height, ob_session, age, atr_value)
            
            if strength >= min_strength_filter
                [norm_top, norm_bot] = normalize_zone(ob_top, ob_bot, true, atr_value)
                
                b = box.new(ob_bar, norm_top, bar_index + 20, norm_bot, 
                     border_color=bull_ob_border, 
                     bgcolor=bull_ob_color, 
                     border_width=2,
                     extend=extend.right)
                
                l = label.new(ob_bar, norm_bot, "Bull OB", 
                     color=color.new(#089981, 20), 
                     textcolor=color.white, 
                     style=label.style_label_up, 
                     size=size.small)
                
                info_l = label(na)
                if show_ob_info
                    pips = calc_pips(zone_height)
                    distance_pips = calc_pips(math.abs(close - ((norm_top + norm_bot) / 2)))
                    info_text = "Bullish OB ||| Strength: " + str.tostring(math.round(strength * 10) / 10) + "/10 ||| " + ob_session + " ||| Age: 0 bars ||| " + str.tostring(pips) + " pips ||| " + str.tostring(distance_pips) + " pips away"
                    mid_price = (norm_top + norm_bot) / 2
                    
                    // EXACT LOGIC FROM SOURCE: Fully transparent background, solid text color
                    info_l := label.new(bar_index + 25, mid_price, info_text,
                         color=color.new(#089981, 100),  // Fully transparent background
                         textcolor=color.new(#089981, 0),  // Solid green text
                         style=label.style_label_left,
                         size=get_text_size(ob_info_size),
                         textalign=text.align_left)
                
                new_ob = OB.new(b, l, info_l, norm_top, norm_bot, ob_bar, true, ob_session, ob_bar, strength)
                array.push(bull_obs, new_ob)

    // Bearish OB
    if not na(swing_high_ob)
        bool found = false
        float ob_top = na
        float ob_bot = na
        int ob_bar = na
        int ob_time_offset = na
        
        for i = ob_swing_length + 1 to ob_swing_length + ob_lookback
            if not found
                hist_close = close[i]
                hist_open = open[i]
                hist_high = high[i]
                hist_low = low[i]
                
                if hist_close > hist_open
                    disp = hist_high - swing_high_ob
                    rng = hist_high - hist_low
                    
                    if disp > (rng * ob_displacement_mult) and rng > 0
                        ob_top := hist_high
                        ob_bot := hist_low
                        ob_bar := bar_index - i
                        ob_time_offset := i
                        found := true

        if found and not na(ob_top)
            ob_session = get_session(time[ob_time_offset])
            age = 0
            displacement = ob_top - close
            zone_height = ob_top - ob_bot
            strength = calculate_ob_strength(displacement, zone_height, ob_session, age, atr_value)
            
            if strength >= min_strength_filter
                [norm_top, norm_bot] = normalize_zone(ob_top, ob_bot, false, atr_value)
                
                b = box.new(ob_bar, norm_top, bar_index + 20, norm_bot, 
                     border_color=bear_ob_border, 
                     bgcolor=bear_ob_color, 
                     border_width=2,
                     extend=extend.right)
                
                l = label.new(ob_bar, norm_top, "Bear OB", 
                     color=color.new(#f23645, 20), 
                     textcolor=color.white, 
                     style=label.style_label_down, 
                     size=size.small)
                
                info_l = label(na)
                if show_ob_info
                    pips = calc_pips(zone_height)
                    distance_pips = calc_pips(math.abs(close - ((norm_top + norm_bot) / 2)))
                    info_text = "Bearish OB ||| Strength: " + str.tostring(math.round(strength * 10) / 10) + "/10 ||| " + ob_session + " ||| Age: 0 bars ||| " + str.tostring(pips) + " pips ||| " + str.tostring(distance_pips) + " pips away"
                    mid_price = (norm_top + norm_bot) / 2
                    
                    // EXACT LOGIC FROM SOURCE: Fully transparent background, solid text color
