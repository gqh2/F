if show_liquidity
    atr_eqhl = ta.atr(eqhl_atr_length)
    threshold_value = atr_eqhl * eqhl_threshold
    
    // Pivot detection
    ph = eqhl_wait_confirmation ? ta.pivothigh(eqhl_pivot_length, eqhl_pivot_length) : ta.pivothigh(eqhl_pivot_length, 1)
    pl = eqhl_wait_confirmation ? ta.pivotlow(eqhl_pivot_length, eqhl_pivot_length) : ta.pivotlow(eqhl_pivot_length, 1)
    
    // Equal Highs Detection
    if not na(ph)
        max_high = math.max(ph, previousHigh)
        min_high = math.min(ph, previousHigh)
        
        if max_high < min_high + threshold_value
            // Draw line connecting equal highs
            line.new(highLocX, previousHigh, 
                 eqhl_wait_confirmation ? bar_index - eqhl_pivot_length : bar_index - 1, ph, 
                 color=color.new(color.red, 0), width=2, style=line.style_solid)
            
            // Draw RED EQH label
            label.new(int(math.avg(eqhl_wait_confirmation ? bar_index - eqhl_pivot_length : bar_index - 1, highLocX)), ph, 
                 "EQH", 
                 color=color.new(color.black, 100), 
                 textcolor=color.new(color.red, 0), 
                 style=label.style_none, 
                 size=size.normal)
        
        previousHigh := ph
        highLocX := eqhl_wait_confirmation ? bar_index - eqhl_pivot_length : bar_index - 1
    
    // Equal Lows Detection
